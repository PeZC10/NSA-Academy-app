{
  "name": "nsc-academy",
  "version": "1.0.2",
  "description": "NSC Academy — Generador de Exámenes",
  "author": "NSC",
  "main": "main.js",
  "scripts": {
    "postinstall": "node scripts/prepare-vendors.js",
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@babel/standalone": "7.29.0",
    "docx": "8.5.0"
  },
  "build": {
    "appId": "com.nsc.academy",
    "productName": "NSC Academy",
    "copyright": "NSC",
    "files": [
      "main.js",
      "app/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NSC Academy"
    },
    "mac": {
      "category": "public.app-category.education",
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
